# Global
JWT_SECRET=replace_with_strong_secret
FERNET_KEY=replace_with_fernet_key

# AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama2

# SerpAPI (web search)
SERPAPI_API_KEY=
SERPAPI_ENGINE=google_news
SERPAPI_TBM=
SERPAPI_NUM_RESULTS=8
SERPAPI_GL=
SERPAPI_HL=

# Google Sign-In (OpenID Connect) - OAuth Client ID (NOT an API key)
GOOGLE_OAUTH_CLIENT_ID=
SERPAPI_NEWS_CROSSCHECK=true
SERPAPI_NEWS_CROSSCHECK_ENGINE=google
SERPAPI_NEWS_CROSSCHECK_TBM=nws
PUBLIC_BASE_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost:5173

# API
DATABASE_URL=postgresql+psycopg2://flowberry:flowberry@postgres:5432/flowberry
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
API_PREFIX=/api/v1

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
